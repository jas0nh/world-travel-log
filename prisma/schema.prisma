generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PlaceLevel {
  COUNTRY
  REGION
  CITY
}

enum DatePrecision {
  UNKNOWN
  YEAR
  MONTH
  DAY
}

enum VisitStatus {
  VISITED
  PLANNED
}

model Place {
  id          String      @id
  name        String
  nativeName  String?
  level       PlaceLevel
  code        String?
  isoNumeric  String?
  countryCode String?
  lat         Float
  lng         Float
  parentId    String?
  parent      Place?      @relation("PlaceChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Place[]     @relation("PlaceChildren")
  visits      Visit[]
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([level])
  @@index([parentId])
  @@index([countryCode])
  @@index([isoNumeric])
}

model User {
  id        String   @id
  name      String
  visits    Visit[]
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id            String        @id @default(cuid())
  userId        String        @default("user-jason")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId       String
  place         Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  status        VisitStatus   @default(VISITED)
  visitedAt     DateTime?
  datePrecision DatePrecision @default(UNKNOWN)
  visitedYear   Int?
  visitedMonth  Int?
  visitedDay    Int?
  isDerived     Boolean       @default(false)
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, placeId])
  @@index([placeId])
  @@index([userId])
}

model MapLayerCache {
  id          String   @id
  placeId     String?
  level       PlaceLevel
  source      String
  attribution String
  dataPath    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([placeId])
  @@index([level])
}
